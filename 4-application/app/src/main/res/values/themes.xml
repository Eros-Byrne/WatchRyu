<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Mobdevportfolio" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Noctua Brown Theme -->
    <style name="Theme.Mobdevportfolio.Brown" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/noctua_dark_brown</item>
        <item name="colorPrimaryVariant">@color/noctua_dark_brown</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/noctua_medium_brown</item>
        <item name="android:windowBackground">@color/noctua_background</item>
        <item name="android:textColorPrimary">@color/noctua_dark_brown</item>
    </style>
</resources>