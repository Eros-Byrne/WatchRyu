<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Light/Dark/Auto) -->
    <style name="Theme.WatchRyu" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <!-- Default text sizes -->
        <item name="textSizeSmall">12sp</item>
        <item name="textSizeMedium">14sp</item>
        <item name="textSizeLarge">18sp</item>
    </style>

    <!-- High Contrast Overlays -->
    <style name="Theme.WatchRyu.HighContrast">
        <item name="colorOnSurface">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/black</item>
    </style>

    <style name="Theme.WatchRyu.HighContrast.Dark">
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
    </style>

    <!-- Font Size Overlays -->
    <style name="Theme.WatchRyu.FontSmall">
        <item name="android:textSize">12sp</item>
        <item name="textSizeSmall">10sp</item>
        <item name="textSizeMedium">12sp</item>
        <item name="textSizeLarge">16sp</item>
    </style>
    <style name="Theme.WatchRyu.FontMedium">
        <item name="android:textSize">16sp</item>
        <item name="textSizeSmall">12sp</item>
        <item name="textSizeMedium">14sp</item>
        <item name="textSizeLarge">20sp</item>
    </style>
    <style name="Theme.WatchRyu.FontLarge">
        <item name="android:textSize">20sp</item>
        <item name="textSizeSmall">16sp</item>
        <item name="textSizeMedium">18sp</item>
        <item name="textSizeLarge">24sp</item>
    </style>
</resources>
